# Build/runtime artifacts (any location)
*.7z
*.parquet
*_tokens.jsonl
*.batchstate.json

# data/: track only the per-language word-pair corpora (small .csv.gz, <100MB).
# Large raw rolls (>100MB) and derived files stay out of git -> host on Dataverse
# (GitHub hard-rejects files >100MB).
/data/*
!/data/*.csv.gz
# Re-ignore raw rolls (corpora are named <language>.csv.gz; rolls carry _all / year / region):
/data/*_all*.csv.gz
/data/*_train_v2.csv.gz
/data/*_20[0-9][0-9].csv.gz
/data/*_guj_*.csv.gz
.DS_Store
